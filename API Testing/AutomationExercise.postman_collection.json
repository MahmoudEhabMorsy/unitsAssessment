        {
          "name": "GET user account detail by email",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "pm.test(\"Body matches string\", function () {\r",
                  "    let name = pm.collectionVariables.get(\"name\");\r",
                  "    let email = pm.collectionVariables.get(\"validEmail\");\r",
                  "    let title = pm.collectionVariables.get(\"title\");\r",
                  "    let birth_day = pm.collectionVariables.get(\"birth_date\");\r",
                  "    let birth_month = pm.collectionVariables.get(\"birth_month\");\r",
                  "    let birth_year = pm.collectionVariables.get(\"birth_year\");\r",
                  "    let first_name = pm.collectionVariables.get(\"firstname\");\r",
                  "    let last_name = pm.collectionVariables.get(\"lastname\");\r",
                  "    let company = pm.collectionVariables.get(\"company\");\r",
                  "    let address1 = pm.collectionVariables.get(\"address1\");\r",
                  "    let address2 = pm.collectionVariables.get(\"address2\");\r",
                  "    let country = pm.collectionVariables.get(\"country\");\r",
                  "    let state = pm.collectionVariables.get(\"state\");\r",
                  "    let city = pm.collectionVariables.get(\"city\");\r",
                  "    let zipcode = pm.collectionVariables.get(\"zipcode\");\r",
                  "   \r",
                  "    pm.expect(pm.response.json().user.name).to.eql(name);\r",
                  "    pm.expect(pm.response.json().user.email).to.eql(email);\r",
                  "    pm.expect(pm.response.json().user.title).to.eql(title);\r",
                  "    pm.expect(pm.response.json().user.birth_day).to.eql(birth_day);\r",
                  "    pm.expect(pm.response.json().user.birth_month).to.eql(birth_month);\r",
                  "    pm.expect(pm.response.json().user.birth_year).to.eql(birth_year);\r",
                  "    pm.expect(pm.response.json().user.first_name).to.eql(first_name);\r",

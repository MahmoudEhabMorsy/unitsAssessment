      "name": "Products API",
      "item": [
        {
          "name": "Get All Products List",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "pm.test(\"Body matches string\", function () {\r",
                  "    pm.expect(pm.response.text()).to.include(\"id\");\r",
                  "    pm.expect(pm.response.text()).to.include(\"name\");\r",
                  "    pm.expect(pm.response.text()).to.include(\"price\");\r",
                  "    pm.expect(pm.response.text()).to.include(\"brand\");\r",
                  "    pm.expect(pm.response.text()).to.include(\"category\"); \r",
                  "});\r",
                  "//to make sure at least one product is listed\r",
                  "pm.test(\"Body has a total of \"+pm.response.json().products.length+\" Products\", function () {\r",
                  " pm.expect(pm.response.json().products.length).to.greaterThan(1);\r",
                  "});\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{productsListUrl}}",
              "host": [
                "{{productsListUrl}}"
              ]
            }
          },
          "response": []
        },
